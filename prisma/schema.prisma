// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

// Muy importante la propiedad moduleFormat
// Previene de este error:  Object.defineProperty(exports, "__esModule", { value: true });
//                          ReferenceError: exports is not defined in ES module scope
// Si se cambia este archivo se debe regenerar el cliente: npx prisma generate

generator client {
  provider      = "prisma-client"
  output        = "../generated/prisma"

  // Muy importante esta propiedad:
  moduleFormat  = "cjs"
}

datasource db {
  provider = "sqlite"
}

model Product { 
  id    Int     @id @default(autoincrement()) 
  name  String @unique
  price Float

  avaiable Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Se crea un índice porque estará presente en la mayoría de las queries
  @@index([avaiable])
} 